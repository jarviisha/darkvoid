# ---------------------------------------------------------------------------
# DarkVoid environment template
# Copy to .env for local development. Do not commit real secrets.
# ---------------------------------------------------------------------------

# Application
SERVICE_NAME=darkvoid
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# Logger
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ADD_SOURCE=false

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_REQUEST_TIMEOUT=60s
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Database
# When running the app on the host, DB_HOST should usually be localhost.
# Docker Compose overrides DB_HOST to the postgres service name automatically.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=darkvoid
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DATABASE_URL=postgres://postgres:postgres@localhost:5432/darkvoid?sslmode=disable

# Optional host port overrides for docker-compose.override.yml
DB_EXPOSE_PORT=5433
REDIS_EXPOSE_PORT=6380
QDRANT_HTTP_PORT=6335
QDRANT_GRPC_PORT=6336
CODOHUE_EXPOSE_PORT=2002

# App-only Docker mode: make docker-up-app
# These are the addresses the app container uses to reach infra outside compose.
EXTERNAL_DB_HOST=host.docker.internal
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_SSLMODE=disable
EXTERNAL_REDIS_HOST=host.docker.internal
EXTERNAL_REDIS_PORT=6379
EXTERNAL_CODOHUE_BASE_URL=http://host.docker.internal:2002

# JWT and refresh tokens
# Production must set JWT_SECRET to a strong random value.
JWT_SECRET=change-this-secret-key-in-production-use-at-least-32-characters
JWT_ISSUER=darkvoid
JWT_ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# Storage
STORAGE_PROVIDER=local
STORAGE_BASE_URL=http://localhost:8080/static
STORAGE_LOCAL_DIR=./uploads
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_BUCKET=darkvoid
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_USE_SSL=false

# Root bootstrap
# Leave ROOT_EMAIL or ROOT_PASSWORD empty to disable automatic root creation.
ROOT_EMAIL=
ROOT_PASSWORD=
ROOT_USERNAME=root
ROOT_DISPLAY_NAME=Root Admin

# Redis
# Docker Compose enables Redis for the app container automatically.
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# Feed timeline rollout and fanout
# Timeline serving is off by default. Fanout may prepare timelines before serving.
FEED_TIMELINE_ENABLED=false
FEED_TIMELINE_ROLLOUT_PERCENT=0
FEED_TIMELINE_MAX_ITEMS=1000
FEED_TIMELINE_TTL=168h
FEED_FANOUT_ENABLED=true
FEED_FANOUT_WORKERS=10
FEED_FANOUT_QUEUE_SIZE=10000
FEED_FANOUT_MAX_FOLLOWERS=10000
FEED_TIMELINE_REFRESH_ON_MISS=true

# Codohue personalization service
# Enable only when running the codohue profile: make docker-up-codohue
CODOHUE_ENABLED=false
CODOHUE_BASE_URL=http://localhost:2002
# CODOHUE_DOCKER_BASE_URL=http://codohue-api:2001
CODOHUE_NAMESPACE=darkvoid_feed
CODOHUE_EMBEDDING_DIM=64
# CODOHUE_NAMESPACE_KEY=
# CODOHUE_ADMIN_KEY=
# CODOHUE_API_KEY=
# If REDIS_PASSWORD is set and Codohue runs in Docker, set this explicitly:
# CODOHUE_REDIS_URL=redis://:yourpassword@redis:6379

# Mailer
# Use nop locally unless you need to test real delivery.
MAILER_PROVIDER=nop
# MAILER_HOST=smtp.gmail.com
# MAILER_PORT=587
# MAILER_USERNAME=your-email@example.com
# MAILER_PASSWORD=your-app-password
# MAILER_FROM=DarkVoid <your-email@example.com>
# MAILER_BASE_URL=http://localhost:3000
