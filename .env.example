# Application Configuration
SERVICE_NAME=darkvoid
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# Logger Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ADD_SOURCE=false

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me-local-db-password
DB_NAME=darkvoid
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

# Migration Database URL (for golang-migrate CLI)
DATABASE_URL=postgres://postgres:${DB_PASSWORD}@localhost:5432/darkvoid?sslmode=disable

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_REQUEST_TIMEOUT=60s
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# JWT Configuration (access token)
JWT_SECRET=change-this-secret-key-in-production-use-at-least-32-characters
JWT_ISSUER=darkvoid
JWT_ACCESS_TOKEN_EXPIRY=15m

# Refresh Token Configuration
REFRESH_TOKEN_EXPIRY=168h

# Storage Configuration
# STORAGE_PROVIDER selects the backend: "local" or "s3" (default: nop/placeholder)
STORAGE_PROVIDER=local
# STORAGE_BASE_URL is the public base URL used to build file URLs from keys
STORAGE_BASE_URL=http://localhost:8080/static
# Local provider: directory to store uploaded files
STORAGE_LOCAL_DIR=./uploads
# S3-compatible provider (S3, MinIO, GCS)
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_USE_SSL=false

# Root Bootstrap Configuration (Cách 3 - auto-bootstrap)
# Set ROOT_EMAIL + ROOT_PASSWORD to auto-create the root user on first startup.
# No-op if any user already exists. Leave empty to disable.
ROOT_EMAIL=root@darkvoid.com
ROOT_PASSWORD=Root@1234
ROOT_USERNAME=root
ROOT_DISPLAY_NAME=Root Admin

# Redis Configuration
# Set REDIS_ENABLED=true to enable caching (default: false)
REDIS_ENABLED=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_POOL_SIZE=10

# Codohue Personalization Service Configuration
# Set CODOHUE_ENABLED=true to enable CF recommendations and behavior event tracking (default: false → local scoring only).
# Requires Redis to be enabled for event publishing via Redis Streams.
#
# Auth: two-tier — namespace key for all runtime calls; admin key only for one-time namespace provisioning.
# CODOHUE_NAMESPACE_KEY is returned once when the namespace is created via PUT /v1/config/namespaces/{ns}.
CODOHUE_ENABLED=false
# CODOHUE_BASE_URL=http://codohue-host:2001
# CODOHUE_NAMESPACE_KEY=ns_abc123...   # returned once on namespace creation — store immediately
# CODOHUE_ADMIN_KEY=                   # admin key — only for namespace provisioning, not used at runtime
# CODOHUE_NAMESPACE=darkvoid_feed
# CODOHUE_EMBEDDING_DIM=64             # must match embedding_dim in namespace config (default: 64)

# Mailer Configuration
# Set MAILER_PROVIDER=smtp to enable real email delivery (default: nop → emails are logged only)
# See docs/gmail-smtp-setup.md for Gmail configuration guide
MAILER_PROVIDER=nop
# MAILER_HOST=smtp.gmail.com
# MAILER_PORT=587
# MAILER_USERNAME=your-email@gmail.com
# MAILER_PASSWORD=xxxx xxxx xxxx xxxx
# MAILER_FROM=DarkVoid <your-email@gmail.com>
# MAILER_BASE_URL=http://localhost:3000
